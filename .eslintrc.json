{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "airbnb-base",
    "plugin:storybook/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [
          ".js",
          ".jsx"
        ]
      }
    }
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": [
      "error",
      {
        "varsIgnorePattern": "^[A-Z_]"
      }
    ],
    "no-param-reassign": [
      "error",
      {
        "props": true,
        "ignorePropertyModificationsFor": [
          "state"
        ]
      }
    ],
    "no-underscore-dangle": "off",
    "import/prefer-default-export": "off",
    "max-len": [
      "error",
      {
        "code": 185
      }
    ],
    "no-alert": "off",
    "consistent-return": "off",
    "import/no-unresolved": "off",
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": [
          "vite.config.js",
          "**/*.test.js",
          "**/*.spec.js",
          "eslint.config.js"
        ]
      }
    ]
  }
}